LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=qwen3.5-flash
LLM_PLANNING_MODEL=qwen3.5-flash
LLM_MAX_CONCURRENCY=1
LLM_IMAGE_REQUEST_TIMEOUT_SECONDS=120

vllm_base_url=https://dashscope.aliyuncs.com/compatible-mode/v1
vllm_api_key=your_vllm_api_key
vllm_model=qwen3-vl-flash

## 可选配置(没有也能运行)
# 如果你需要网络搜索功能
TAVILY_API_KEY=your_tavily_api_key
TAVILY_BASE_URL=https://api.tavily.com
# 如果你需要RAG检索功能，目前只支持混元embedding模型，需要混元api key
RAG_embedding_model_key=your_rag_embedding_model_key
# 如果你希望每次启动时都重置agent的记忆，可以将下面的值改为true
MEMORY_RESET_ON_START=false

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

MAX_UPLOAD_IMAGE_BYTES=4194304
REQUEST_TIMEOUT_SECONDS=30

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=XiaoZhi
LANGSMITH_ENDPOINT=https://api.smith.langchain.com