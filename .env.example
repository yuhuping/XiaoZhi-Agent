APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Preferred provider config (SCNet OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.scnet.cn/api/llm/v1
LLM_API_KEY=
LLM_MODEL=Qwen3-235B-A22B
LLM_PLANNING_MODEL=Qwen3-235B-A22B
LLM_MAX_CONCURRENCY=1
LLM_IMAGE_REQUEST_TIMEOUT_SECONDS=120

MAX_UPLOAD_IMAGE_BYTES=4194304
REQUEST_TIMEOUT_SECONDS=60

# v1.3 local RAG + memory
KG_DIR=./KG
RAG_ENABLED=true
RAG_TOP_K=3
RAG_MIN_SCORE=0.08
RAG_CHUNK_SIZE=520
RAG_CHUNK_OVERLAP=80
RAG_REFRESH_INTERVAL_SECONDS=2
KG_AUTO_BOOTSTRAP=true
PROFILE_DB_PATH=./data/profile_memory.sqlite3
MEMORY_RESET_ON_START=false

# Optional web search tool (Tavily)
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_MAX_RESULTS=3
TAVILY_SEARCH_DEPTH=basic
TAVILY_TIMEOUT_SECONDS=15
